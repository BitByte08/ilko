<Window x:Class="Ilko.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ILKO" Width="860" Height="540"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar ──────────────────────────────────── -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Ellipse Width="9" Height="9" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="I L K O" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Style="{StaticResource IconBtn}" ToolTip="최소화"
                            Click="OnMinimize" WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </Button>
                    <Button Style="{StaticResource IconBtn}" ToolTip="닫기"
                            Click="OnClose" WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── Body ──────────────────────────────────────── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── 사이드바: 프로필 목록 ─────────────────── -->
                <Border Grid.Column="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>

                        <!-- 사이드바 헤더 -->
                        <DockPanel DockPanel.Dock="Top" Margin="14,12,8,8">
                            <Button Style="{StaticResource IconBtn}" ToolTip="프로필 추가"
                                    DockPanel.Dock="Right"
                                    Click="OnAddProfileClick"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="{StaticResource TextDimBrush}"/>
                            </Button>
                            <TextBlock Text="프로필" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- 프로필 목록 -->
                        <ScrollViewer DockPanel.Dock="Bottom"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="8,0,8,8">
                            <ItemsControl x:Name="ProfileList" ItemsSource="{Binding Profiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,4" CornerRadius="8"
                                                BorderThickness="1.5" Cursor="Hand"
                                                Padding="10,8"
                                                MouseLeftButtonUp="OnProfileClick">
                                            <Border.BorderBrush>
                                                <MultiBinding Converter="{StaticResource IsEqualToBrushConverter}">
                                                    <Binding Path="Id"/>
                                                    <Binding Path="DataContext.ActiveProfileId"
                                                             RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </Border.BorderBrush>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2A2A40"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <DockPanel>
                                                <!-- 편집/삭제 버튼 -->
                                                <StackPanel DockPanel.Dock="Right"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Button Style="{StaticResource IconBtn}"
                                                            Padding="2" ToolTip="편집"
                                                            Tag="{Binding}"
                                                            Click="OnEditProfileClick"
                                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                                        <TextBlock Text="&#xE70F;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextDimBrush}"/>
                                                    </Button>
                                                    <Button Style="{StaticResource IconBtn}"
                                                            Padding="2" ToolTip="삭제"
                                                            Tag="{Binding}"
                                                            Click="OnDeleteProfileClick"
                                                            Visibility="{Binding GatewayMAC, TargetNullValue=Collapsed, FallbackValue=Visible}"
                                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                                        <TextBlock Text="&#xE74D;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource DangerBrush}"/>
                                                    </Button>
                                                </StackPanel>

                                                <!-- 프로필 정보 -->
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock FontSize="10" Margin="0,2,0,0"
                                                               Foreground="{StaticResource TextDimBrush}"
                                                               Text="{Binding GatewayMAC, TargetNullValue='기본 프로필'}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ── 메인: 현재 활성 프로필 상태 ────────────── -->
                <Grid Grid.Column="1" Margin="24,20,24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 배경화면 미리보기 -->
                    <Border Grid.Row="0" CornerRadius="12"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            ClipToBounds="True">
                        <Grid>
                            <Image x:Name="ActiveWallpaperPreview"
                                   Stretch="UniformToFill"
                                   Source="{Binding ActiveProfile.WallpaperPath,
                                            Converter={StaticResource PathToImageConverter}}"/>

                            <!-- 동영상 배지 -->
                            <Border x:Name="VideoBadge"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="12" Background="#CC000000" CornerRadius="6"
                                    Padding="8,4"
                                    Visibility="{Binding ActiveProfile.VideoPath,
                                                 TargetNullValue=Collapsed, FallbackValue=Visible}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE102;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Margin="0,0,5,0" Foreground="White"/>
                                    <TextBlock Text="동영상" FontSize="12" Foreground="White"/>
                                </StackPanel>
                            </Border>

                            <!-- 빈 상태 안내 -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding ActiveProfile.WallpaperPath,
                                                     TargetNullValue=Visible, FallbackValue=Collapsed}">
                                <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="40" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12"/>
                                <TextBlock Text="활성 배경화면 없음"
                                           FontSize="13" Foreground="{StaticResource TextDimBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 활성 프로필 정보 + 툴바 -->
                    <DockPanel Grid.Row="1" Margin="0,12,0,0">
                        <!-- 새로고침 버튼 -->
                        <Button Style="{StaticResource IconBtn}" ToolTip="네트워크 새로고침"
                                DockPanel.Dock="Right"
                                Click="OnRefreshClick">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Foreground="{StaticResource TextDimBrush}"/>
                        </Button>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="SemiBold">
                                <Run Text="{Binding ActiveProfile.Name, TargetNullValue='활성 프로필 없음', FallbackValue='활성 프로필 없음'}"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="{StaticResource TextDimBrush}"
                                       Margin="0,3,0,0">
                                <Run Text="네트워크  "/>
                                <Run Text="{Binding CurrentNetworkId, TargetNullValue='감지 중...'}"
                                     Foreground="{StaticResource AccentBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </Grid>

            <!-- ── Status Bar ─────────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <DockPanel Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="NetworkDot" Width="7" Height="7"
                                 Fill="{StaticResource TextDimBrush}" Margin="0,0,6,0"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextDimBrush}">
                            <Run Text="네트워크  "/>
                            <Run Text="{Binding CurrentNetworkId, TargetNullValue='감지 중...'}"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               FontSize="11" Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center">
                        <Run Text="활성  "/>
                        <Run Text="{Binding ActiveProfile.Name, TargetNullValue='없음', FallbackValue='없음'}"
                             Foreground="{StaticResource AccentBrush}"/>
                    </TextBlock>
                </DockPanel>
            </Border>

        </Grid>
    </Border>
</Window>
