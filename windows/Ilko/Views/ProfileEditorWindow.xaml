<Window x:Class="Ilko.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프로필 편집" Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="0"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- 타이틀 바 -->
            <Grid DockPanel.Dock="Top" Height="40" Background="{StaticResource SurfaceBrush}">
                <TextBlock x:Name="TitleText" Text="프로필 추가"
                           FontSize="13" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Style="{StaticResource IconBtn}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,4,0" Click="OnCancel"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource TextDimBrush}"/>
                </Button>
            </Grid>

            <!-- 바디 -->
            <StackPanel Margin="24,16,24,20">

                <!-- 이름 -->
                <TextBlock Text="이름" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="NameBox" Margin="0,0,0,14"/>

                <!-- 네트워크 -->
                <TextBlock Text="네트워크" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                           Margin="0,0,0,5"/>
                <DockPanel Margin="0,0,0,16">
                    <Button x:Name="UseCurrentBtn" Content="현재로" DockPanel.Dock="Right"
                            Style="{StaticResource FlatBtn}" FontSize="12" Padding="10,6"
                            Click="OnUseCurrentNetwork" Margin="8,0,0,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Border Background="{StaticResource Surface2Brush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,7">
                        <TextBlock x:Name="MacText" FontFamily="Consolas" FontSize="12"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </DockPanel>

                <!-- 모니터별 월페이퍼 -->
                <TextBlock Text="모니터별 월페이퍼" FontSize="11"
                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,8"/>

                <ItemsControl x:Name="MonitorList" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                <DockPanel>
                                    <Button Style="{StaticResource IconBtn}"
                                            ToolTip="파일 선택" DockPanel.Dock="Right"
                                            Tag="{Binding}" Click="OnPickMonitorFile"
                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="15"
                                                   Foreground="{StaticResource TextDimBrush}"/>
                                    </Button>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FriendlyName}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock FontSize="11" Margin="0,3,0,0"
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="340"
                                                   Text="{Binding CurrentPath, TargetNullValue='선택 없음 (기본 월페이퍼 사용)'}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 기본 월페이퍼 (fallback) -->
                <TextBlock Text="기본 월페이퍼 (모니터 개별 설정 없을 때)" FontSize="11"
                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5"/>
                <DockPanel Margin="0,0,0,16">
                    <Button Style="{StaticResource IconBtn}"
                            ToolTip="파일 선택" DockPanel.Dock="Right"
                            Click="OnPickDefaultFile" Margin="8,0,0,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </Button>
                    <Border Background="{StaticResource Surface2Brush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,7">
                        <TextBlock x:Name="DefaultWallpaperText" FontSize="12"
                                   Foreground="{StaticResource TextDimBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </DockPanel>

                <!-- 정렬 방식 -->
                <TextBlock Text="정렬 방식" FontSize="11"
                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,8"/>
                <WrapPanel x:Name="PositionPanel" Margin="0,0,0,16"/>

                <!-- 오프셋 (Center 모드일 때) -->
                <StackPanel x:Name="OffsetSection" Visibility="Collapsed" Margin="0,0,0,16">
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="오프셋 (Center 모드)" FontSize="11"
                               Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10"/>

                    <TextBlock FontSize="11" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4">
                        <Run Text="X  "/>
                        <Run x:Name="OffsetXLabel" Text="0"/>
                        <Run Text=" px"/>
                    </TextBlock>
                    <Slider x:Name="SliderX" Minimum="-600" Maximum="600" Value="0"
                            IsSnapToTickEnabled="False"
                            Foreground="{StaticResource AccentBrush}"
                            Margin="0,0,0,10"
                            ValueChanged="OnOffsetXChanged"/>

                    <TextBlock FontSize="11" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4">
                        <Run Text="Y  "/>
                        <Run x:Name="OffsetYLabel" Text="0"/>
                        <Run Text=" px"/>
                    </TextBlock>
                    <Slider x:Name="SliderY" Minimum="-600" Maximum="600" Value="0"
                            IsSnapToTickEnabled="False"
                            Foreground="{StaticResource AccentBrush}"
                            Margin="0,0,0,0"
                            ValueChanged="OnOffsetYChanged"/>
                </StackPanel>

                <!-- 미리보기 -->
                <Border x:Name="PreviewBorder" CornerRadius="8"
                        Background="{StaticResource Surface2Brush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Height="110" Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
                </Border>

                <!-- 구분선 -->
                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

                <!-- 버튼 -->
                <DockPanel>
                    <Button Content="취소" Style="{StaticResource FlatBtn}"
                            Click="OnCancel" MinWidth="90" Margin="0,0,8,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Content="저장" Style="{StaticResource AccentBtn}"
                            Click="OnSave" MinWidth="90" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>

            </StackPanel>
        </DockPanel>
    </Border>
</Window>
