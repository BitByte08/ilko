<Window x:Class="Ilko.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프로필 편집" Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <DockPanel Margin="24" LastChildFill="False">

        <!-- 제목 -->
        <TextBlock DockPanel.Dock="Top" x:Name="TitleText" Text="프로필 추가"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

        <!-- 이름 -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="이름" Width="80" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>
            <TextBox x:Name="NameBox" Padding="8,6"
                     Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource TextBrush}"
                     BorderBrush="{StaticResource BorderBrush}"/>
        </DockPanel>

        <!-- 네트워크 -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="네트워크" Width="80" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>
            <Button x:Name="UseCurrentBtn" Content="현재 네트워크로"
                    Style="{StaticResource IlkoButton}" FontSize="12"
                    Click="OnUseCurrentNetwork" DockPanel.Dock="Right"/>
            <TextBlock x:Name="MacText" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center" FontFamily="Consolas"
                       Margin="0,0,8,0" TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <!-- 월페이퍼 -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="월페이퍼" Width="80" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>
            <Button Content="파일 선택" Style="{StaticResource IlkoButton}" FontSize="12"
                    Click="OnPickFile" DockPanel.Dock="Right"/>
            <TextBlock x:Name="WallpaperText" Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                       Margin="0,0,8,0"/>
        </DockPanel>

        <!-- 미리보기 -->
        <Border DockPanel.Dock="Top" CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                Height="120" Margin="0,0,0,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
        </Border>

        <Separator DockPanel.Dock="Top" Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

        <!-- 버튼들 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Style="{StaticResource IlkoButton}"
                    Click="OnCancel" Margin="0,0,8,0" MinWidth="80"/>
            <Button x:Name="SaveBtn" Content="저장" Style="{StaticResource AccentButton}"
                    Click="OnSave" MinWidth="80"/>
        </StackPanel>

    </DockPanel>
</Window>
