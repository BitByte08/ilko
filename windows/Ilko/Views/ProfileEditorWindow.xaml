<Window x:Class="Ilko.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프로필 편집" Width="480" Height="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Grid.Row="0" x:Name="TitleText" Text="프로필 추가"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

        <!-- 이름 -->
        <DockPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="이름" Width="80" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>
            <TextBox x:Name="NameBox" Padding="8,6"
                     Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource TextBrush}"
                     BorderBrush="{StaticResource BorderBrush}"/>
        </DockPanel>

        <!-- 네트워크 -->
        <DockPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="네트워크" Width="80" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="MacText" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center" FontFamily="Consolas"
                       Margin="0,0,8,0"/>
            <Button x:Name="UseCurrentBtn" Content="현재 네트워크로"
                    Style="{StaticResource IlkoButton}" FontSize="12"
                    Click="OnUseCurrentNetwork" HorizontalAlignment="Left"/>
        </DockPanel>

        <!-- 월페이퍼 -->
        <DockPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="월페이퍼" Width="80" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>
            <Button Content="파일 선택" Style="{StaticResource IlkoButton}" FontSize="12"
                    Click="OnPickFile" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <TextBlock x:Name="WallpaperText" Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <!-- 미리보기 -->
        <Border Grid.Row="4" CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                Height="120" Margin="0,0,0,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
        </Border>

        <!-- 스페이서 -->
        <Grid Grid.Row="5"/>

        <!-- 버튼들 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Style="{StaticResource IlkoButton}"
                    Click="OnCancel" Margin="0,0,8,0" MinWidth="80"/>
            <Button x:Name="SaveBtn" Content="저장" Style="{StaticResource AccentButton}"
                    Click="OnSave" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
