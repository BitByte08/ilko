<Window x:Class="Ilko.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ILKO" Width="680" Height="520"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar ──────────────────────────────── -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Ellipse Width="9" Height="9" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="I L K O" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Content="&#xE921;" Style="{StaticResource IconBtn}" ToolTip="최소화"
                            Click="OnMinimize" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource IconBtn}" ToolTip="닫기"
                            Click="OnClose" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>

            <!-- ── Content ────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="14,12,14,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 툴바 -->
                <DockPanel Grid.Row="0" Margin="2,0,2,10">
                    <TextBlock Text="프로필" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#xE72C;" Style="{StaticResource IconBtn}"
                                ToolTip="네트워크 새로고침" Click="OnRefreshClick"/>
                        <Button Content="&#xE710;" Style="{StaticResource IconBtn}"
                                ToolTip="프로필 추가" Click="OnAddProfileClick"/>
                    </StackPanel>
                </DockPanel>

                <!-- 프로필 목록 -->
                <Border Grid.Row="1" CornerRadius="10"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <ScrollViewer Padding="8" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ProfileList" ItemsSource="{Binding Profiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="Card" CornerRadius="8" Margin="0,0,0,5"
                                            Padding="14,11"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="OnProfileClick">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock FontSize="11" Margin="0,3,0,0"
                                                           Foreground="{StaticResource TextDimBrush}"
                                                           Text="{Binding GatewayMAC, TargetNullValue='기본 프로필'}"/>
                                                <TextBlock FontSize="11" Margin="0,2,0,0"
                                                           Foreground="{StaticResource TextDimBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="380"
                                                           Text="{Binding WallpaperPath, TargetNullValue='월페이퍼 없음'}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="&#xE70F;" Style="{StaticResource IconBtn}"
                                                        ToolTip="편집" Tag="{Binding}"
                                                        Click="OnEditProfileClick"
                                                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                                                <Button Content="&#xE74D;" Style="{StaticResource DangerIconBtn}"
                                                        ToolTip="삭제" Tag="{Binding}"
                                                        Click="OnDeleteProfileClick"
                                                        WindowChrome.IsHitTestVisibleInChrome="True"
                                                        Visibility="{Binding GatewayMAC, TargetNullValue=Collapsed, FallbackValue=Visible}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── Status Bar ─────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <DockPanel Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="NetworkDot" Width="7" Height="7"
                                 Fill="{StaticResource TextDimBrush}" Margin="0,0,6,0"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextDimBrush}">
                            <Run Text="네트워크  "/><Run x:Name="NetworkIdText" Text="감지 중..."/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               FontSize="11" Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center">
                        <Run Text="활성  "/>
                        <Run x:Name="ActiveProfileText" Text="없음"
                             Foreground="{StaticResource AccentBrush}"/>
                    </TextBlock>
                </DockPanel>
            </Border>

        </Grid>
    </Border>
</Window>
