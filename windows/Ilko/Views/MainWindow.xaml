<Window x:Class="Ilko.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Ilko.Converters"
        Title="ILKO" Width="860" Height="540"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar ──────────────────────────────────── -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Ellipse Width="9" Height="9" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="I L K O" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Style="{StaticResource IconBtn}" ToolTip="최소화"
                            Click="OnMinimize" WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </Button>
                    <Button Style="{StaticResource IconBtn}" ToolTip="닫기"
                            Click="OnClose" WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── Body ──────────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="14,12,14,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 툴바 -->
                <DockPanel Grid.Row="0" Margin="2,0,2,10">
                    <TextBlock Text="프로필" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource IconBtn}" ToolTip="네트워크 새로고침"
                                Click="OnRefreshClick">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Foreground="{StaticResource TextDimBrush}"/>
                        </Button>
                        <Button Style="{StaticResource IconBtn}" ToolTip="프로필 추가"
                                Click="OnAddProfileClick">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Foreground="{StaticResource TextDimBrush}"/>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <!-- 프로필 타일 그리드 -->
                <Border Grid.Row="1" CornerRadius="10"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <ScrollViewer Padding="10,10,6,10" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ProfileList" ItemsSource="{Binding Profiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- 프로필 타일 -->
                                    <Border Width="182" Margin="0,0,8,8" CornerRadius="10"
                                            BorderThickness="1.5" Cursor="Hand"
                                            MouseLeftButtonUp="OnProfileClick">
                                        <Border.BorderBrush>
                                            <MultiBinding Converter="{StaticResource IsEqualToBrushConverter}">
                                                <Binding Path="Id"/>
                                                <Binding Path="DataContext.ActiveProfileId"
                                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            </MultiBinding>
                                        </Border.BorderBrush>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2A2A40"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="103"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 썸네일 -->
                                            <Border Grid.Row="0" CornerRadius="9,9,0,0"
                                                    ClipToBounds="True"
                                                    Background="{StaticResource BgBrush}">
                                                <Image Stretch="UniformToFill">
                                                    <Image.Source>
                                                        <Binding Path="WallpaperPath"
                                                                 Converter="{StaticResource PathToImageConverter}"/>
                                                    </Image.Source>
                                                </Image>
                                            </Border>

                                            <!-- 정보 행 -->
                                            <DockPanel Grid.Row="1" Margin="10,7,5,8">
                                                <StackPanel DockPanel.Dock="Right"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Top">
                                                    <Button Style="{StaticResource IconBtn}" Padding="3"
                                                            ToolTip="편집" Tag="{Binding}"
                                                            Click="OnEditProfileClick"
                                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                                        <TextBlock Text="&#xE70F;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextDimBrush}"/>
                                                    </Button>
                                                    <Button Style="{StaticResource IconBtn}" Padding="3"
                                                            ToolTip="삭제" Tag="{Binding}"
                                                            Click="OnDeleteProfileClick"
                                                            Visibility="{Binding GatewayMAC, TargetNullValue=Collapsed, FallbackValue=Visible}"
                                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                                        <TextBlock Text="&#xE74D;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource DangerBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                                <StackPanel VerticalAlignment="Center" Margin="0,0,2,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock FontSize="10" Margin="0,2,0,0"
                                                               Foreground="{StaticResource TextDimBrush}"
                                                               Text="{Binding GatewayMAC, TargetNullValue='기본 프로필'}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── Status Bar ─────────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <DockPanel Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="NetworkDot" Width="7" Height="7"
                                 Fill="{StaticResource TextDimBrush}" Margin="0,0,6,0"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextDimBrush}">
                            <Run Text="네트워크  "/>
                            <Run Text="{Binding CurrentNetworkId, TargetNullValue='감지 중...'}"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               FontSize="11" Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center">
                        <Run Text="활성  "/>
                        <Run Text="{Binding ActiveProfile.Name, TargetNullValue='없음', FallbackValue='없음'}"
                             Foreground="{StaticResource AccentBrush}"/>
                    </TextBlock>
                </DockPanel>
            </Border>

        </Grid>
    </Border>
</Window>
