<Window x:Class="Ilko.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ILKO" Width="700" Height="550"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="500" MinHeight="400">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더: 타이틀 + 툴바 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="ILKO" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" DockPanel.Dock="Left"
                       VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Style="{StaticResource IlkoButton}" ToolTip="새로고침"
                        Click="OnRefreshClick" Margin="0,0,8,0"/>
                <Button Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Style="{StaticResource AccentButton}" ToolTip="프로필 추가"
                        Click="OnAddProfileClick"/>
            </StackPanel>
        </DockPanel>

        <!-- 프로필 리스트 -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                CornerRadius="12" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ProfileList" ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" CornerRadius="8"
                                    Margin="4" Padding="14,10"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="OnProfileClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}네트워크: {0}">
                                                        <Binding Path="GatewayMAC" TargetNullValue="기본 프로필"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="350" HorizontalAlignment="Left">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}월페이퍼: {0}">
                                                    <Binding Path="WallpaperPath" TargetNullValue="없음"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                                Style="{StaticResource IlkoButton}" ToolTip="편집"
                                                Click="OnEditProfileClick" Tag="{Binding}" Margin="0,0,4,0"/>
                                        <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                Style="{StaticResource DangerButton}" ToolTip="삭제"
                                                Click="OnDeleteProfileClick" Tag="{Binding}"
                                                Visibility="{Binding GatewayMAC, TargetNullValue=Collapsed, FallbackValue=Visible}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 상태 바 -->
        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="현재 네트워크: "/>
                <Run x:Name="NetworkIdText" Text="감지 중..."/>
            </TextBlock>
            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="활성: "/>
                <Run x:Name="ActiveProfileText" Text="없음"/>
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
